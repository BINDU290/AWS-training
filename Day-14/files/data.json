{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Data Stack - S3 bucket configured for public static website hosting with bucket policy, versioning, and lifecycle rules.",

  "Parameters": {
    "EnvironmentName": {
      "Type": "String",
      "Default": "nginx-app"
    },
    "BucketName": {
      "Type": "String",
      "Description": "Globally unique S3 bucket name. Must be lowercase, no spaces.",
      "AllowedPattern": "[a-z0-9][a-z0-9\\-]{2,62}",
      "ConstraintDescription": "Must be 3-63 characters, lowercase letters, numbers, and hyphens only."
    },
    "EnableVersioning": {
      "Type": "String",
      "Default": "Enabled",
      "AllowedValues": ["Enabled", "Suspended"]
    }
  },

  "Resources": {

    "StaticWebsiteBucket": {
      "Type": "AWS::S3::Bucket",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "BucketName": { "Ref": "BucketName" },
        "WebsiteConfiguration": {
          "IndexDocument": "index.html",
          "ErrorDocument": "error.html"
        },
        "VersioningConfiguration": {
          "Status": { "Ref": "EnableVersioning" }
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": false,
          "BlockPublicPolicy": false,
          "IgnorePublicAcls": false,
          "RestrictPublicBuckets": false
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "CorsConfiguration": {
          "CorsRules": [
            {
              "AllowedHeaders": ["*"],
              "AllowedMethods": ["GET"],
              "AllowedOrigins": ["*"],
              "MaxAge": 3600
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "expire-old-versions",
              "Status": "Enabled",
              "NoncurrentVersionExpirationInDays": 90
            },
            {
              "Id": "abort-incomplete-multipart",
              "Status": "Enabled",
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 7
              }
            }
          ]
        },
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "${EnvironmentName}-static-site" } },
          { "Key": "Environment", "Value": { "Ref": "EnvironmentName" } }
        ]
      }
    },

    "StaticWebsiteBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": { "Ref": "StaticWebsiteBucket" },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "PublicReadGetObject",
              "Effect": "Allow",
              "Principal": "*",
              "Action": "s3:GetObject",
              "Resource": { "Fn::Sub": "arn:aws:s3:::${BucketName}/*" }
            }
          ]
        }
      }
    }
  },

  "Outputs": {
    "BucketName": {
      "Description": "S3 bucket name",
      "Value": { "Ref": "StaticWebsiteBucket" },
      "Export": { "Name": { "Fn::Sub": "${EnvironmentName}-BucketName" } }
    },
    "BucketArn": {
      "Description": "S3 bucket ARN",
      "Value": { "Fn::GetAtt": ["StaticWebsiteBucket", "Arn"] },
      "Export": { "Name": { "Fn::Sub": "${EnvironmentName}-BucketArn" } }
    },
    "WebsiteURL": {
      "Description": "S3 static website endpoint URL",
      "Value": { "Fn::GetAtt": ["StaticWebsiteBucket", "WebsiteURL"] },
      "Export": { "Name": { "Fn::Sub": "${EnvironmentName}-WebsiteURL" } }
    },
    "BucketRegionalDomainName": {
      "Description": "Regional domain name for CloudFront origin",
      "Value": { "Fn::GetAtt": ["StaticWebsiteBucket", "RegionalDomainName"] },
      "Export": { "Name": { "Fn::Sub": "${EnvironmentName}-BucketDomainName" } }
    }
  }
}
